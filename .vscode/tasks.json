{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Compilar SFML + IA",
      "command": "C:/msys64/ucrt64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-std=c++20",
        "-g",

        "${workspaceFolder}/gato.cpp",
        "${workspaceFolder}/IA.cpp",

        "-o",
        "${workspaceFolder}/gato.exe",

        "-IC:/msys64/ucrt64/include",
        "-LC:/msys64/ucrt64/lib",

        "-lsfml-graphics",
        "-lsfml-window",
        "-lsfml-system",
        "-lsfml-audio"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    {
      "label": "Ejecutar Gato",
      "type": "shell",
      "command": "\"${workspaceFolder}/gato.exe\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": "Compilar SFML + IA"
    }
  ]
}
